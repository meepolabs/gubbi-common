# Canonical .editorconfig.
#
# COPY TO `.editorconfig` AT REPO ROOT.

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{js,ts,svelte,json,jsonc}]
indent_style = tab

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{md,mdx,svx}]
trim_trailing_whitespace = false
